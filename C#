// ============================================================
// EJERCICIO 19: Conversión de horas a turnos (Switch con when)
// ============================================================
using System;

class Ejercicio19
{
    static void Main()
    {
        Console.Write("Ingresa la hora (0-23): ");
        int hora = Convert.ToInt32(Console.ReadLine());

        switch (hora)
        {
            case int h when h >= 0  && h <= 5:  Console.WriteLine("Madrugada"); break;
            case int h when h >= 6  && h <= 11: Console.WriteLine("Mañana");    break;
            case int h when h >= 12 && h <= 17: Console.WriteLine("Tarde");     break;
            case int h when h >= 18 && h <= 23: Console.WriteLine("Noche");     break;
            default: Console.WriteLine("Hora inválida."); break;
        }
    }
}


// ============================================================
// EJERCICIO 20: Clasificación de IMC
// ============================================================
using System;

class Ejercicio20
{
    static void Main()
    {
        Console.Write("Ingresa tu peso en kg: ");
        double peso = Convert.ToDouble(Console.ReadLine());

        Console.Write("Ingresa tu altura en metros (ej. 1.75): ");
        double altura = Convert.ToDouble(Console.ReadLine());

        if (altura <= 0)
        {
            Console.WriteLine("La altura debe ser mayor a 0.");
            return;
        }

        double imc = peso / (altura * altura);
        Console.WriteLine($"\nTu IMC es: {imc:F2}");

        if (imc < 18.5)
            Console.WriteLine("Clasificación: Bajo peso.");
        else if (imc < 25)
            Console.WriteLine("Clasificación: Normal.");
        else if (imc < 30)
            Console.WriteLine("Clasificación: Sobrepeso.");
        else
            Console.WriteLine("Clasificación: Obesidad.");
    }
}
