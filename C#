// ============================================================
// EJERCICIO 14: Conversión de calificaciones a letra (Switch con when)
// ============================================================
using System;

class Ejercicio14
{
    static void Main()
    {
        Console.Write("Ingresa la calificación (0-100): ");
        int cal = Convert.ToInt32(Console.ReadLine());

        char letra;

        switch (cal)
        {
            case int n when n >= 90 && n <= 100: letra = 'A'; break;
            case int n when n >= 80:             letra = 'B'; break;
            case int n when n >= 70:             letra = 'C'; break;
            case int n when n >= 60:             letra = 'D'; break;
            case int n when n >= 0:              letra = 'F'; break;
            default:
                Console.WriteLine("Calificación inválida.");
                return;
        }

        Console.WriteLine($"Tu calificación en letra es: {letra}");
    }
}


