// ============================================================
// EJERCICIO 11: Cálculo de impuestos
// ============================================================
using System;

class Ejercicio11
{
    static void Main()
    {
        Console.Write("Ingresa tu salario mensual: ");
        double salario = Convert.ToDouble(Console.ReadLine());

        double impuesto;
        double porcentaje;

        if (salario < 10000)
        {
            porcentaje = 0;
            impuesto   = 0;
        }
        else if (salario <= 30000)
        {
            porcentaje = 10;
            impuesto   = salario * 0.10;
        }
        else
        {
            porcentaje = 20;
            impuesto   = salario * 0.20;
        }

        Console.WriteLine($"Porcentaje de impuesto: {porcentaje}%");
        Console.WriteLine($"Impuesto a pagar: {impuesto:F2}");
        Console.WriteLine($"Salario neto: {salario - impuesto:F2}");
    }
}


// ============================================================
// EJERCICIO 12: Clasificación de números (positivos, negativos, mixtos, ceros)
// ============================================================
using System;

class Ejercicio12
{
    static void Main()
    {
        Console.Write("Ingresa el primer número:  ");
        double a = Convert.ToDouble(Console.ReadLine());

        Console.Write("Ingresa el segundo número: ");
        double b = Convert.ToDouble(Console.ReadLine());

        Console.Write("Ingresa el tercer número:  ");
        double c = Convert.ToDouble(Console.ReadLine());

        bool hayPositivos = a > 0 || b > 0 || c > 0;
        bool hayNegativos = a < 0 || b < 0 || c < 0;
        bool hayCeros     = a == 0 || b == 0 || c == 0;

        if (hayCeros)
            Console.WriteLine("Al menos uno de los números es cero.");
        else if (hayPositivos && hayNegativos)
            Console.WriteLine("Los números son mixtos (positivos y negativos).");
        else if (hayPositivos)
            Console.WriteLine("Todos los números son positivos.");
        else
            Console.WriteLine("Todos los números son negativos.");
    }
}


