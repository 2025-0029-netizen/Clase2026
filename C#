// ============================================================
// EJERCICIO 17: Tipo de triángulo
// ============================================================
using System;

class Ejercicio17
{
    static void Main()
    {
        Console.Write("Ingresa el primer lado:  ");
        double a = Convert.ToDouble(Console.ReadLine());

        Console.Write("Ingresa el segundo lado: ");
        double b = Convert.ToDouble(Console.ReadLine());

        Console.Write("Ingresa el tercer lado:  ");
        double c = Convert.ToDouble(Console.ReadLine());

        // Primero verificamos que forme un triángulo válido
        if (!(a + b > c && a + c > b && b + c > a))
        {
            Console.WriteLine("Esos lados no forman un triángulo válido.");
            return;
        }

        if (a == b && b == c)
            Console.WriteLine("El triángulo es equilátero.");
        else if (a == b || b == c || a == c)
            Console.WriteLine("El triángulo es isósceles.");
        else
            Console.WriteLine("El triángulo es escaleno.");
    }
}


